{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Auto Push to GitHub",
      "type": "shell",
      "command": "git add . && git commit -m \"auto update\" && git push",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
